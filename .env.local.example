# Environment variable template
# Preferred keys: AUTH_SECRET and AUTH_URL
# Legacy aliases NEXTAUTH_SECRET and NEXTAUTH_URL are still supported

# Required to boot the app
SUNUFARM_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
AUTH_SECRET=[GENERATE_WITH_OPENSSL_RAND_BASE64_32]
AUTH_URL=http://localhost:3000

# Recommended in local and production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: direct database connection for migrations or admin tooling
# SUNUFARM_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Optional: automatic notifications cron protection
CRON_SECRET=[GENERATE_A_LONG_RANDOM_SECRET]

# Optional: transactional and digest emails
# `MAIL_FROM` must use a domain verified in Resend.
# Do not use `@resend.dev` for real recipients.
# RESEND_API_KEY=re_xxx
# MAIL_FROM=SunuFarm <no-reply@sunufarm.example>
# ADMIN_ALERT_EMAILS=owner@example.com,ops@example.com

# Optional: Wave checkout and payment webhooks
# WAVE_API_KEY=wave_xxx
# WAVE_WEBHOOK_SECRET=wave_whsec_xxx
# PAYMENT_WEBHOOK_SECRET=payment_whsec_xxx

# Optional: AI analysis
# OPENAI_API_KEY=sk-xxx
